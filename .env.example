# Runtime mode: demo, test, or production.
CONVAGENT_RUNTIME_MODE=demo

# LLM provider. Never place a real credential in this file.
CONVAGENT_LLM_PROVIDER=dashscope
CONVAGENT_DASHSCOPE_API_KEY=
CONVAGENT_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CONVAGENT_LLM_DEFAULT_PROFILE=standard
CONVAGENT_LLM_STANDARD_MODEL=qwen3-8b
CONVAGENT_LLM_STANDARD_THINKING=false

# Optional historical providers. Never commit real credentials.
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=

# PostgreSQL credential. Keep the value empty in committed examples.
CONVAGENT_DATABASE_URL=

# OIDC-compatible JWT resource-server configuration.
CONVAGENT_OIDC_ISSUER=
CONVAGENT_OIDC_AUDIENCE=
CONVAGENT_OIDC_JWKS_URL=
CONVAGENT_OIDC_TENANT_ID=single_tenant
CONVAGENT_OIDC_EXPECTED_ORGANIZATION_ID=default_organization
CONVAGENT_OIDC_CLOCK_SKEW_SECONDS=60
CONVAGENT_OIDC_MAX_TOKEN_LIFETIME_SECONDS=3600
CONVAGENT_OIDC_MAX_TOKEN_BYTES=8192
CONVAGENT_OIDC_MIN_RSA_KEY_SIZE_BITS=2048
CONVAGENT_OIDC_MAX_KID_BYTES=128
CONVAGENT_OIDC_JWKS_CACHE_TTL_SECONDS=300
CONVAGENT_OIDC_NEGATIVE_KID_TTL_SECONDS=10
CONVAGENT_OIDC_JWKS_MAX_RESPONSE_BYTES=262144
CONVAGENT_OIDC_JWKS_MAX_KEYS=20
CONVAGENT_OIDC_JWKS_TIMEOUT_SECONDS=5
CONVAGENT_OIDC_TOKEN_USE_CLAIM=token_use
CONVAGENT_OIDC_TOKEN_USE_VALUE=access
CONVAGENT_OIDC_REQUIRED_TYP=

# API documentation is normally disabled in production.
CONVAGENT_API_DOCS_ENABLED=true

# External RAG service.
CONVAGENT_RAG_PROVIDER=external
CONVAGENT_RAG_BASE_URL=http://127.0.0.1:8001
CONVAGENT_RAG_TIMEOUT_SECONDS=30
CONVAGENT_RAG_FALLBACK_TO_LOCAL=true
CONVAGENT_RAG_INCLUDE_RAW_RESPONSE=false

# Local data and logging.
CONVERSATION_AGENT_DATA_DIR=./data
CONVERSATION_AGENT_LOG_LEVEL=INFO
